rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is platform admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    // ── Existing collections ──────────────────────────
    match /users/{uid} {
      allow read: if isLoggedIn();
      allow write: if request.auth.uid == uid || isAdmin();
    }

    match /jugadores/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /torneos/{docId} {
      allow read, write: if isLoggedIn();

      match /participantes/{partId} {
        allow read, write: if isLoggedIn();
      }
    }

    match /jornadas/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /resultados/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /clubes/{docId} {
      allow read, write: if isLoggedIn();
    }

    // ── Wallet ────────────────────────────────────────
    match /wallets/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();
      allow write: if request.auth.uid == uid || isAdmin();
    }

    match /transactions/{docId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isAdmin();
    }

    match /app_config/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /pago_movil_recargas/{docId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isAdmin();
    }

    // ── Inscripciones ─────────────────────────────────
    match /inscripciones/{docId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
    }
  }
}
